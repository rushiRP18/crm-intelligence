# ==============================================================
# SenAI CRM Intelligence Platform — Environment Configuration
# ==============================================================
# Copy this to .env and fill in your actual values

# --- HuggingFace ---
HUGGINGFACE_API_KEY=hf_your_api_key_here

# --- LangSmith Observability ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_your_langsmith_key_here
LANGCHAIN_PROJECT=crm-intelligence
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# --- Database ---
DATABASE_URL=sqlite:///./crm_intelligence.db

# --- ChromaDB ---
CHROMA_PERSIST_DIR=./chroma_db

# --- LLM Settings ---
# HuggingFace model for classification + agent reasoning
HF_LLM_MODEL=mistralai/Mistral-7B-Instruct-v0.3
# Local embedding model (downloaded automatically, no API key needed)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- App Settings ---
APP_ENV=development
LOG_LEVEL=INFO
MAX_AGENT_TOOL_CALLS=6
RAG_TOP_K=3
RAG_MIN_SCORE=0.3
CONFIDENCE_HUMAN_THRESHOLD=0.70
SENTIMENT_DETERIORATION_COUNT=3
WEB_INTEL_CACHE_HOURS=6
EMAIL_REPLAY_SPEED=1.0

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
